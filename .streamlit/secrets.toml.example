# このファイルをコピーして secrets.toml にリネームし、実際の値を入力してください。
# secrets.toml は .gitignore に追加済みのため、GitHubにはpushされません。
# Streamlit Community Cloud へのデプロイ時は、管理画面の「Secrets」欄に同じ内容を貼り付けてください。

# ── アクセスパスワード ──────────────────────────────────────
password = "your-password-here"

# ── データベース（Supabase等のPostgreSQL接続文字列）──────────
# ローカル開発時は .env の DATABASE_URL が使われるため不要
DATABASE_URL = "postgresql://user:password@host:5432/dbname"

# ── APIキー ─────────────────────────────────────────────────
GEMINI_API_KEY = "your-gemini-api-key"
DEEPL_API_KEY = "your-deepl-api-key"
# SEMANTIC_SCHOLAR_API_KEY = "your-s2-api-key"  # 任意
